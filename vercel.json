{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/terms", "destination": "/public/terms.html" },
    { "source": "/privacy", "destination": "/public/privacy.html" },
    { "source": "/(.*)", "destination": "/public/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/reset-usage",
      "schedule": "0 0 1 * *"
    }
  ]
}
